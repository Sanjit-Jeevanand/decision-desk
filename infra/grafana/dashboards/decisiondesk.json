{
  "title": "DecisionDesk",
  "uid": "decisiondesk-main",
  "schemaVersion": 38,
  "refresh": "10s",
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Active Sessions",
      "gridPos": {"x":0,"y":0,"w":4,"h":4},
      "targets": [{"expr": "decisiondesk_active_sessions_total", "legendFormat": "sessions"}],
      "options": {"colorMode": "background", "graphMode": "none"}
    },
    {
      "id": 2, "type": "stat", "title": "Reviews / min",
      "gridPos": {"x":4,"y":0,"w":4,"h":4},
      "targets": [{"expr": "rate(decisiondesk_reviews_total[1m]) * 60", "legendFormat": "rpm"}],
      "options": {"colorMode": "value", "graphMode": "area"}
    },
    {
      "id": 3, "type": "stat", "title": "P95 Latency",
      "gridPos": {"x":8,"y":0,"w":4,"h":4},
      "targets": [{"expr": "histogram_quantile(0.95, rate(decisiondesk_review_duration_seconds_bucket[5m]))", "legendFormat": "p95"}],
      "options": {"colorMode": "background", "graphMode": "none"},
      "fieldConfig": {"defaults": {"unit": "s", "thresholds": {"steps": [
        {"color":"green","value":null},
        {"color":"yellow","value":45},
        {"color":"red","value":60}
      ]}}}
    },
    {
      "id": 4, "type": "timeseries", "title": "Review Duration (P50 / P95 / P99)",
      "gridPos": {"x":0,"y":4,"w":12,"h":8},
      "targets": [
        {"expr": "histogram_quantile(0.50, rate(decisiondesk_review_duration_seconds_bucket[5m]))", "legendFormat": "p50"},
        {"expr": "histogram_quantile(0.95, rate(decisiondesk_review_duration_seconds_bucket[5m]))", "legendFormat": "p95"},
        {"expr": "histogram_quantile(0.99, rate(decisiondesk_review_duration_seconds_bucket[5m]))", "legendFormat": "p99"}
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "id": 5, "type": "timeseries", "title": "Gate Outcomes",
      "gridPos": {"x":12,"y":4,"w":12,"h":8},
      "targets": [
        {"expr": "rate(decisiondesk_reviews_total{outcome='approved'}[1m])", "legendFormat": "approved"},
        {"expr": "rate(decisiondesk_reviews_total{outcome='rejected'}[1m])", "legendFormat": "rejected"},
        {"expr": "rate(decisiondesk_reviews_total{outcome='error'}[1m])", "legendFormat": "error"}
      ]
    }
  ]
}
